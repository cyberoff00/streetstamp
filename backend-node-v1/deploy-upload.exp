spawn scp package.json root@$server:/opt/streetstamps/backend-node-v1/package.json.new
expect "password:" { send "$password\r" }
expect eof

spawn scp package-lock.json root@$server:/opt/streetstamps/backend-node-v1/package-lock.json.new
expect "password:" { send "$password\r" }
expect eof
