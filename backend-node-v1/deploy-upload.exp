#!/usr/bin/expect -f
set timeout 60
set password "Ylinteresting22@"
set server "101.132.159.73"

spawn scp server.js root@$server:/opt/streetstamps/backend-node-v1/server.js.new
expect "password:" { send "$password\r" }
