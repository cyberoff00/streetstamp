# Core
PORT=18080
JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-chars
DATABASE_URL=postgresql://streetstamps:replace-with-db-password@postgres:5432/streetstamps
PGSSL=require
PG_STATE_KEY=global

# Origins
CORS_ALLOWED_ORIGINS=https://app.streetstamps.cyberkkk.cn,https://streetstamps.cyberkkk.cn

# Request limits
JSON_BODY_LIMIT_MB=6
MEDIA_UPLOAD_MAX_BYTES=10485760
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
WRITE_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=40
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=10

# Public URLs
MEDIA_PUBLIC_BASE=https://worldo-api.cyberkkk.cn
AUTH_LINK_BASE=https://worldo-api.cyberkkk.cn
APPSTORE_FALLBACK_URL=https://apps.apple.com/us/search?term=StreetStamps

# Mail
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_BASE=https://api.resend.com
SES_FROM_EMAIL=

# Apple
APPLE_AUDIENCES=com.claire.streetstamps

# APNs Push Notifications
APNS_KEY_PATH=/opt/streetstamps/apns/AuthKey.p8
APNS_KEY_ID=MUBQXCQG7K
APNS_TEAM_ID=XNPB3GQ7SF
APNS_USE_SANDBOX=false

# Object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_PUBLIC_BASE=https://media-worldo.cyberkkk.cn
